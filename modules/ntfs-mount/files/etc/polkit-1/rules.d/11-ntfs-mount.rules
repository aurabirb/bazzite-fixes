/* Allow wheel group members to run ntfs-mount.sh via pkexec without a password.
   The script needs root for ntfsfix but calls udisksctl as the original user. */
polkit.addRule(function(action, subject) {
    if (action.id == "org.freedesktop.policykit.exec" &&
        action.lookup("program") == "/usr/local/bin/ntfs-mount.sh" &&
        subject.isInGroup("wheel")) {
        return polkit.Result.YES;
    }
});
